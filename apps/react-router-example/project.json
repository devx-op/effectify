{
  "name": "@effectify/react-router-example",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/react-router-example/src",
  "projectType": "application",
  "tags": [],
  "// targets": "to see all targets run: nx show project react-router-example --web",
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run",
        "cwd": "apps/react-router-example"
      }
    },
    "test:browser": {
      "executor": "nx:run-commands",
      "dependsOn": ["typegen", "prisma:generate", "build"],
      "options": {
        "command": "node tests/browser/support/run-browser-suite.mjs",
        "cwd": "apps/react-router-example"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc",
        "cwd": "apps/react-router-example"
      },
      "dependsOn": ["typegen", "prisma:generate"]
    },
    "typegen": {
      "executor": "nx:run-commands",
      "options": {
        "command": "react-router typegen",
        "cwd": "apps/react-router-example"
      }
    },
    "prisma:generate": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "command": "pnpm dlx prisma generate",
        "cwd": "apps/react-router-example"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "continuous": true,
      "dependsOn": ["build"],
      "options": {
        "command": "react-router-serve build/server/index.js",
        "cwd": "apps/react-router-example"
      }
    },
    "build": {
      "executor": "@nx/vite:build",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/react-router-example"
      },
      "configurations": {
        "development": {
          "mode": "development"
        },
        "production": {
          "mode": "production"
        }
      },
      "dependsOn": ["typegen", "prisma:generate", "^build"]
    }
  }
}
