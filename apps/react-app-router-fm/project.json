{
  "name": "react-app-router-fm",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/react-app-router-fm/src",
  "projectType": "application",
  "tags": [],
  "// targets": "to see all targets run: nx show project react-app-router-fm --web",
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "react-router typegen && tsc",
        "cwd": "apps/react-app-router-fm"
      },
      "dependsOn": [
        "prisma-generate"
      ]
    },
    "prisma-generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prisma generate",
        "cwd": "apps/react-app-router-fm"
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/prisma/schema.prisma",
        "{projectRoot}/prisma.config.ts"
      ],
      "outputs": [
        "{projectRoot}/prisma/generated"
      ],
      "dependsOn": [
        {
          "target": "build",
          "projects": ["@effectify/prisma"]
        }
      ]
    },
    "build": {
      "executor": "@nx/vite:build",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/react-app-router-fm"
      },
      "configurations": {
        "development": {
          "mode": "development"
        },
        "production": {
          "mode": "production"
        }
      },
      "dependsOn": [
        "prisma-generate"
      ]
    }
  }
}
