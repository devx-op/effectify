{
  "name": "@effectify/prisma",
  "version": "2.0.0-alpha.2",
  "description": "Prisma generator and runtime utilities for Effect",
  "repository": {
    "type": "git",
    "url": "https://github.com/devx-op/effectify",
    "directory": "packages/prisma"
  },
  "main": "./src/cli.js",
  "type": "module",
  "license": "MIT",
  "bin": {
    "effect-prisma": "./dist/src/cli.js"
  },
  "exports": {
    ".": "./dist/src/runtime/index.js",
    "./prisma": "./dist/prisma/index.js",
    "./cli": "./src/cli.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prisma:generate": "pnpm dlx prisma generate",
    "build": "effect-build",
    "test": "vitest",
    "dev": "tsx src/messaround.ts",
    "cli": "pnpm dlx tsx src/cli.ts"
  },
  "keywords": [],
  "author": "",
  "packageManager": "pnpm@10.14.0",
  "dependencies": {
    "@dprint/formatter": "catalog:",
    "@dprint/typescript": "catalog:",
    "@prisma/generator-helper": "catalog:",
    "eta": "catalog:",
    "kysely": "catalog:"
  },
  "peerDependencies": {
    "@effect/platform-node": "catalog:",
    "@prisma/client": "catalog:",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/build-utils": "catalog:",
    "@effect/experimental": "catalog:",
    "@effect/language-service": "catalog:",
    "@effect/vitest": "catalog:",
    "@prisma/adapter-better-sqlite3": "catalog:",
    "@prisma/client-runtime-utils": "7.3.0",
    "@prisma/generator": "catalog:",
    "@prisma/internals": "catalog:",
    "@types/better-sqlite3": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "better-sqlite3": "catalog:",
    "bun": "1.3.0",
    "dprint": "catalog:",
    "oxlint": "catalog:",
    "prisma": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite-tsconfig-paths": "catalog:",
    "vitest": "catalog:"
  }
}
