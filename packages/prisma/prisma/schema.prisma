// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

generator effect {
  provider = "tsx ./src/cli.ts"
  output           = "./generated/effect" // relative to the schema.prisma file, e.g. prisma/generated/effect
  clientImport     = "../client/index.js"
  clientImportPath = "../client.js" // relative to the output path ^here (defaults to "@prisma/client")
  importFileExtension = "js"
}

datasource db {
  provider = "sqlite"
}

model Todo {
  id        String  @id @default(uuid())
  title     String
  content   String?
  published Boolean @default(false)
  authorId  Int
}
