{
  "name": "@effectify/loom",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/loom/web/src",
  "projectType": "library",
  "tags": ["loom", "public", "web"],
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p tsconfig.lib.json && tsc --noEmit -p tsconfig.spec.json",
        "cwd": "packages/loom/web"
      }
    },
    "lint": {
      "executor": "nx-oxlint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["packages/loom/web/**/*.{ts,tsx,js,jsx,mts,cts}"]
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec vitest run --config vitest.config.mts",
        "cwd": "packages/loom/web"
      }
    }
  }
}
