{
  "name": "@effectify/loom",
  "version": "0.0.1",
  "description": "Effect-native web surface for Loom",
  "repository": {
    "type": "git",
    "url": "https://github.com/devx-op/effectify",
    "directory": "packages/loom/web"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "@effectify/source": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./Component": "./src/component.ts",
    "./Html": "./src/html.ts",
    "./Hydration": "./src/hydration.ts",
    "./Resumability": "./src/resumability.ts"
  },
  "dependencies": {
    "@effectify/loom-core": "workspace:*",
    "@effectify/loom-runtime": "workspace:*",
    "effect": "catalog:",
    "tslib": "catalog:"
  },
  "peerDependencies": {
    "effect": "^4.0.0-beta"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "jsdom": "catalog:",
    "vitest": "catalog:"
  }
}
