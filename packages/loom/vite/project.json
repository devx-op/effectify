{
  "name": "@effectify/loom-vite",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/loom/vite/src",
  "projectType": "library",
  "tags": ["loom", "public", "vite"],
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p tsconfig.lib.json && tsc --noEmit -p tsconfig.spec.json",
        "cwd": "packages/loom/vite"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec vitest run --config vitest.config.mts",
        "cwd": "packages/loom/vite"
      }
    },
    "lint": {
      "executor": "nx-oxlint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["packages/loom/vite/**/*.{ts,tsx,js,jsx,mts,cts}"]
      }
    }
  }
}
