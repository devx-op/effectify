{
  "name": "@effectify/react-remix",
  "version": "0.5.10",
  "description": "Integration of Remix with Effect for React applications",
  "repository": {
    "type": "git",
    "url": "https://github.com/devx-op/effectify",
    "directory": "packages/react/remix"
  },
  "type": "module",
  "main": "./dist/src/index.js",
  "module": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "@effectify/source": "./src/index.ts",
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "dependencies": {},
  "peerDependencies": {
    "@remix-run/node": "catalog:",
    "@remix-run/react": "catalog:",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@remix-run/node": "catalog:",
    "@remix-run/react": "catalog:",
    "effect": "catalog:"
  },
  "optionalDependencies": {}
}
