{
  "name": "@effectify/react-router-better-auth",
  "version": "1.0.0-alpha.3",
  "description": "Integration of React Router + better-auth with Effect for React applications",
  "repository": {
    "type": "git",
    "url": "https://github.com/devx-op/effectify",
    "directory": "packages/react/router-better-auth"
  },
  "type": "module",
  "main": "./dist/src/index.js",
  "module": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "@effectify/source": "./src/index.ts",
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "peerDependencies": {
    "@effectify/react-router": "workspace:*",
    "@effectify/node-better-auth": "workspace:*",
    "effect": "catalog:"
  },
  "devDependencies": {},
  "dependencies": {},
  "optionalDependencies": {}
}
