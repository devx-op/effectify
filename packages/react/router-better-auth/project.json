{
  "name": "@effectify/react-router-better-auth",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/react/router-better-auth/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsgo --build tsconfig.lib.json",
        "cwd": "packages/react/router-better-auth"
      }
    },
    "lint": {
      "executor": "nx-oxlint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": [
          "packages/react/router-better-auth/**/*.{ts,tsx,js,jsx}"
        ]
      }
    }
  },
  "tags": ["node", "react", "react-router", "better-auth", "effect"]
}
