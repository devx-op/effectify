      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "dependencies": {
    "tslib": "catalog:"
  },
  "peerDependencies": {
    "@tanstack/query-core": "^5.90.20",
    "@tanstack/solid-query": "^5.90.23",
    "effect": "^3.19.16 || ^4.0.0-beta",
    "solid-js": "^1.9.11"
  },
  "devDependencies": {
    "@tanstack/query-core": "catalog:",
    "@tanstack/solid-query": "catalog:",
    "effect": "catalog:effect-beta",
    "solid-js": "catalog:",
    "typescript": "catalog:"
  }
}
